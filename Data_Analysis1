import pandas as pd

# Load dataset
df = pd.read_csv("Healthcare_Dataset (1).csv")

# Clean column names
df.columns = df.columns.str.strip().str.lower().str.replace(" ", "_").str.replace(".", "_")

# Standardize Gender
df["gender"] = df["gender"].str.strip().str.upper().replace({"F": "Female", "M": "Male"})

# Convert dates
df["scheduledday"] = pd.to_datetime(df["scheduledday"], dayfirst=True, errors="coerce")
df["appointmentday"] = pd.to_datetime(df["appointmentday"], dayfirst=True, errors="coerce")

# Ensure data types
df["age"] = df["age"].astype(int)

# Remove duplicates and reset index
df = df.drop_duplicates().reset_index(drop=True)

# Save cleaned dataset
df.to_csv("Healthcare_Dataset_Cleaned.csv", index=False)

print("Cleaned dataset saved as Healthcare_Dataset_Cleaned.csv")
